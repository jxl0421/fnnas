[Unit]
Description=ZRAM Memory Compression
After=multi-user.target
Before=swap.target
ConditionPathExists=/usr/local/bin/zram-setup.sh

[Service]
Type=oneshot
ExecStart=/usr/local/bin/zram-setup.sh
ExecStop=/sbin/swapoff /dev/zram0 2>/dev/null || true
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
